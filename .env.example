# Set PASSWORD_PEPPER as Worker Secret:
# wrangler secret put PASSWORD_PEPPER
PASSWORD_PEPPER=please_use_a_long_random_secret
SESSION_TTL_HOURS=168
ADMIN_TOKEN=please_set_a_strong_admin_token
RUNTIME_TARGET=cloudflare
DB_DRIVER=d1
# SQLITE_PATH is used when RUNTIME_TARGET=node and DB_DRIVER=sqlite
SQLITE_PATH=./data/koreader-sync.db
